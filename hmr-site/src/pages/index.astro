---
// HMR Sport Solutions - Astro Conversion v2
---

<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>HMR Sport Solutions | Independent advice for senior decision-makers</title>
    <link rel="icon" type="image/png" href="/favicon-32x32.png" />
    
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@900&family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface text-on-surface antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#eefcfc]/90 dark:bg-[#032829]/90 backdrop-blur-md border-b border-outline-variant/10">
      <nav class="flex justify-between items-center w-full px-6 lg:px-12 py-4 lg:py-6 max-w-screen-2xl mx-auto">
        <div class="text-xl font-black uppercase tracking-tighter text-[#032829] dark:text-[#eefcfc] z-50">
           <img alt="HMR Sport Solutions Logo" class="h-10 lg:h-12 w-auto object-contain" src="/assets/logo-horizontal-black.png" />
        </div>

        <div class="hidden md:flex items-center gap-8">
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#threshold">When to bring me in</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#advisory">How I help</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#evidence">Experience</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#principal">About</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#dialogue">Contact</a>
        </div>

        <a class="hidden md:block bg-primary-container text-on-primary px-6 py-2.5 rounded-sm text-sm font-semibold tracking-tight hover:opacity-90 active:scale-[0.98] transition-all" href="#dialogue">
          Get in touch
        </a>

        <button id="mobile-menu-toggle" class="md:hidden z-50 p-2 text-[#032829] dark:text-[#eefcfc]" aria-label="Toggle mobile menu" aria-expanded="false">
          <svg class="w-8 h-8 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </nav>

      <div id="mobile-menu" class="fixed inset-0 z-40 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col pt-28 px-6 pb-8 gap-8 bg-surface">
        <nav class="flex flex-col gap-6 text-2xl font-bold tracking-tight">
          <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#threshold">When to bring me in</a>
          <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#advisory">How I help</a>
          <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#evidence">Experience</a>
          <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#principal">About</a>
          <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#dialogue">Contact</a>
        </nav>
        <div class="mt-auto">
          <a class="mobile-link block w-full text-center bg-primary-container text-on-primary px-6 py-4 rounded-sm text-lg font-bold hover:opacity-90 active:scale-[0.98] transition-all" href="#dialogue">
            Get in touch
          </a>
        </div>
      </div>
    </header>

    <!-- Mobile Menu - Moved outside header to prevent backdrop-blur from trapping fixed positioning -->
    <div id="mobile-menu" class="fixed inset-0 z-40 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col pt-28 px-6 pb-8 gap-8" style="background-color: var(--menu-bg);">
      <nav class="flex flex-col gap-6 text-2xl font-bold tracking-tight">
        <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#threshold">When to bring me in</a>
        <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#advisory">How I help</a>
        <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#evidence">Experience</a>
        <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#principal">About</a>
        <a class="mobile-link text-[#111e1e] dark:text-[#eefcfc] hover:text-primary transition-colors" href="#dialogue">Contact</a>
      </nav>
      <div class="mt-auto">
        <a class="mobile-link block w-full text-center bg-primary-container text-on-primary px-6 py-4 rounded-sm text-lg font-bold hover:opacity-90 active:scale-[0.98] transition-all" href="#dialogue">
          Get in touch
        </a>
      </div>
    </div>

    <main>
      <section class="relative min-h-screen flex items-center pt-32 pb-16 px-6 lg:px-12 overflow-hidden bg-surface-container-lowest">
        <div class="absolute inset-0 schematic-grid opacity-[0.04] pointer-events-none"></div>
        <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-[0.05] pointer-events-none hidden lg:block">
          <svg fill="none" height="600" viewBox="0 0 600 600" width="600" xmlns="http://www.w3.org/2000/svg">
            <circle cx="200" cy="300" r="199.5" stroke="#01696E"></circle>
            <circle cx="400" cy="300" r="199.5" stroke="#01696E"></circle>
          </svg>
        </div>

        <div class="max-w-7xl mx-auto w-full relative z-10">
          <div class="max-w-5xl">
            <h1 class="font-archivo text-4xl md:text-6xl lg:text-8xl font-black tracking-tight leading-[1.05] md:leading-[0.95] text-primary mb-8 md:mb-10">
              Independent advice when important decisions are still taking shape
            </h1>
        
            <p class="font-body text-lg md:text-xl lg:text-2xl text-on-surface-variant max-w-2xl leading-relaxed mb-10 md:mb-12">
              I work with organisations across sport, recreation, and public-sector settings on complex decisions involving facilities, investment, partnerships, and system response, before commitments are made and before weak assumptions turn into harder problems.
            </p>
            
            <div class="flex flex-col sm:flex-row flex-wrap gap-4 md:gap-6">
              <a class="bg-primary-container text-center text-on-primary px-8 py-4 md:px-10 rounded-sm font-bold tracking-tight hover:opacity-90 transition-all w-full sm:w-auto" href="#dialogue">
                Get in touch
              </a>
              <a class="border border-outline-variant/30 text-center text-on-surface px-8 py-4 md:px-10 rounded-sm font-bold tracking-tight hover:bg-surface-container transition-all w-full sm:w-auto" href="#evidence">
                View experience
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 lg:py-32 px-6 lg:px-12 bg-surface-container-low border-none scroll-mt-20 lg:scroll-mt-28" id="threshold">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
          <div class="lg:col-span-4">
            <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4 uppercase">01 / Timing</span>
            <h2 class="font-archivo text-3xl md:text-4xl font-black text-on-surface mb-6 lg:mb-8">When to bring me in</h2>
          </div>
          <div class="lg:col-span-8">
            <ul class="space-y-4 md:space-y-6 mb-12 lg:mb-16">
              {['direction is not yet settled', 'options are contested', 'investment case is forming', 'pressure to move, but readiness is unclear', 'consequences of getting the next step wrong are material'].map((text) => (
                <li class="flex items-start gap-4 lg:gap-6 group">
                  <span class="material-symbols-outlined text-primary mt-1 md:mt-0" aria-hidden="true">arrow_right_alt</span>
                  <span class="text-xl md:text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">{text}</span>
                </li>
              ))}
            </ul>
            <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">
              This is usually the point where independent advice adds most value, when the direction is still taking shape, the pressure to move is real, and the quality of the next step matters.
            </p>
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 lg:py-32 px-6 lg:px-12 bg-surface scroll-mt-20 lg:scroll-mt-28" id="advisory">
        <div class="max-w-7xl mx-auto">
          <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4 uppercase">02 / Role</span>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20">
            <div>
              <h2 class="font-archivo text-3xl md:text-4xl font-black text-on-surface mb-6 lg:mb-8">How I help</h2>
            </div>
            <div class="font-body text-lg md:text-xl text-on-surface space-y-6 lg:space-y-8 leading-relaxed">
              <p>I provide independent advice when organisations need to decide what to do, why it stacks up, and whether the timing is right.</p>
              <p>The work usually involves clarifying the real decision, testing assumptions and investment logic, working through stakeholder complexity, and assessing sequencing, readiness, and risk.</p>
              <p>I am usually brought in early enough to question the brief, sharpen the case, and reduce the risk of premature lock-in.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 lg:py-32 px-6 lg:px-12 bg-surface-dim scroll-mt-20 lg:scroll-mt-28" id="evidence">
        <div class="max-w-7xl mx-auto">
          <div class="flex flex-col lg:flex-row justify-between items-start lg:items-baseline mb-12 lg:mb-16 gap-6 lg:gap-8">
            <div>
              <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4 uppercase">03 / Experience</span>
              <h2 class="font-archivo text-3xl md:text-4xl font-black text-on-surface">Selected experience</h2>
            </div>
            <p class="text-on-surface-variant max-w-md text-lg leading-relaxed lg:text-right">Experience across sport, recreation, local and central government, and decision-making around facilities, investment, access, and systems.</p>
          </div>

          <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar gap-4 md:grid md:grid-cols-2 xl:grid-cols-3 md:gap-px md:bg-outline-variant/20 md:overflow-visible pb-6 md:pb-0 -mx-6 px-6 md:mx-0 md:px-0">
            {[
              { cat: "PLANNING & INVESTMENT", title: "Local authority planning and investment", desc: "Worked with Auckland local boards on sport and active recreation planning, access, and investment-related decisions." },
              { cat: "LEASING", title: "Public-sector systems and leasing", desc: "Led cross-council work to improve how community leasing decisions support public and community benefit." },
              { cat: "FACILITY DESIGN & OPERATIONS", title: "Hiwa – University of Auckland Recreation Centre", desc: "Worked across design, facility transition, operational setup, and growth, with direct visibility into how early decisions carry through into operating reality." },
              { cat: "SPORT SYSTEMS", title: "National sport and system context", desc: "Worked across Sport New Zealand in roles spanning sport development, system-level work, and management of the Balance is Better digital platform." },
              { cat: "READINESS", title: "Major-event readiness", desc: "Worked within the FIFA Women’s World Cup host city programme across training venue settings." },
              { cat: "FUNDING", title: "Funding and investment administration", desc: "Managed a large regional KiwiSport funding portfolio, with direct responsibility for how investment decisions were administered." }
            ].map((item) => (
              <div class="flex-none w-[85vw] sm:w-[60vw] md:w-auto snap-start bg-white p-8 lg:p-12 min-h-[260px] flex flex-col hover:bg-surface-container-lowest transition-colors border border-outline-variant/20 md:border-none shadow-sm md:shadow-none rounded-md md:rounded-none">
                <div class="max-w-2xl">
                  <span class="text-[10px] md:text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-4 lg:mb-6">{item.cat}</span>
                  <h3 class="text-xl md:text-2xl font-bold mb-3 lg:mb-4">{item.title}</h3>
                  <p class="text-on-surface-variant leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 lg:py-32 px-6 lg:px-12 bg-surface scroll-mt-20 lg:scroll-mt-28" id="principal">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="relative aspect-[4/5] bg-surface-dim overflow-hidden group order-2 lg:order-1">
            <img alt="Portrait of Hamish Rogers" class="portrait-editorial object-cover w-full h-full transition-all duration-700" src="/assets/hamish-portrait.jpg" />
            <div class="absolute inset-0 border-[12px] md:border-[20px] border-surface pointer-events-none"></div>
          </div>

          <div class="order-1 lg:order-2">
            <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4 uppercase">04 / Principal</span>
            <h2 class="font-archivo text-3xl md:text-4xl font-black text-on-surface mb-6 lg:mb-8">About Hamish Rogers</h2>
            <div class="font-body text-lg text-on-surface-variant space-y-6 leading-relaxed">
              <p>My experience has shown me that many important decisions are made before the real problem is fully clear and before the underlying logic has been properly tested.</p>
              <p>Having worked across sport, recreation, facilities, funding, and public-sector environments, I understand how ideas take shape inside organisations, how competing pressures influence direction, and where weak assumptions can harden into more difficult problems later.</p>
              <p>My role is to help bring more clarity to the decision in front of you, test the logic behind it, and improve the quality of the next step before commitments settle in the wrong place.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 lg:py-32 px-6 lg:px-12 bg-surface-container-low scroll-mt-20 lg:scroll-mt-28" id="dialogue">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
            <div class="lg:col-span-5">
              <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4 uppercase">05 / Contact</span>
              <h2 class="font-archivo text-3xl md:text-4xl font-black text-on-surface mb-6 lg:mb-8">Get in touch</h2>
              <p class="text-on-surface-variant text-lg lg:text-xl mb-8 lg:mb-10 leading-relaxed">
                If you are working through a decision like this, get in touch.
              </p>
              <div class="p-6 md:p-8 bg-surface-container-lowest rounded-sm shadow-sm">
                <p class="text-xs font-bold uppercase tracking-widest text-primary mb-2">Direct contact</p>
                <a class="text-lg md:text-xl font-bold hover:text-primary break-all transition-colors" href="mailto:hamish@hmrsportsolutions.co">hamish@hmrsportsolutions.co</a>
              </div>
            </div>

            <div class="lg:col-span-7">
              <form class="space-y-6 md:space-y-8 bg-surface-container-lowest p-6 md:p-10 shadow-sm rounded-sm" id="contact-form">
                 <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-2 block" for="name">Name</label>
                  <input class="w-full bg-transparent border-none p-0 pb-3 min-h-[44px] focus:ring-0 text-on-surface" id="name" name="name" placeholder="" type="text" />
                </div>                

                  <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-2 block" for="organisation">Organisation</label>
                  <input class="w-full bg-transparent border-none p-0 pb-3 min-h-[44px] focus:ring-0 text-on-surface" id="organisation" name="organisation" placeholder="" type="text" />
                </div>

                <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-2 block" for="email">Email</label>
                  <input class="w-full bg-transparent border-none p-0 pb-3 min-h-[44px] focus:ring-0 text-on-surface" id="email" name="email" placeholder="" type="email" required />
                </div>

                <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-2 block" for="message">How can I help?</label>
                  <textarea class="w-full bg-transparent border-none p-0 pb-3 focus:ring-0 text-on-surface resize-none" id="message" name="message" placeholder="" rows="4" required></textarea>
                </div>

                <button class="bg-primary-container text-on-primary w-full md:w-auto px-10 py-4 font-bold tracking-tight hover:opacity-90 active:scale-[0.98] transition-all rounded-sm" type="submit">
                  Send enquiry
                </button>
                <p class="text-sm mt-4 hidden font-medium" id="contact-status"></p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-surface-container-low dark:bg-[#021d1e] w-full py-16 lg:py-20 px-6 lg:px-12 border-t border-outline-variant/10">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end w-full max-w-screen-2xl mx-auto gap-8">
        <div class="space-y-3 lg:space-y-4">
          <div class="text-lg font-black text-[#032829] dark:text-[#eefcfc] uppercase tracking-tighter">
            HMR Sport Solutions
          </div>
          <p class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60">
            HMR Sport Solutions © {new Date().getFullYear()}
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
          <a class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60 hover:opacity-100 hover:text-[#01696E] underline decoration-px underline-offset-4 transition-all" href="https://www.linkedin.com/in/hamishrogers/" target="_blank" rel="noopener noreferrer">
            LinkedIn
          </a>
          <a class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60 hover:opacity-100 hover:text-[#01696E] underline decoration-px underline-offset-4 transition-all" href="/privacy-policy">
            Privacy Policy
          </a>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --menu-bg: #eefcfc;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --menu-bg: #032829;
        }
      }

      /* Base Theme Styles */
      body { 
        font-family: 'Inter', sans-serif;
        background-color: #eefcfc; 
        color: #111e1e; 
      }
      .font-archivo { font-family: 'Archivo', sans-serif; }
      
      /* Decorative Grid */
      .schematic-grid {
        background-image: linear-gradient(#bec9c9 0.5px, transparent 0.5px), 
                          linear-gradient(90deg, #bec9c9 0.5px, transparent 0.5px);
        background-size: 40px 40px;
      }
      
      /* Image Filtering */
      .portrait-editorial {
        filter: grayscale(100%) contrast(1.05) brightness(1.02);
        transform: scale(1);
        transition: filter 0.5s ease, transform 0.5s ease;
      }
      .portrait-editorial:hover {
        filter: grayscale(40%) contrast(1.05) brightness(1.02);
        transform: scale(1.02);
      }
      
      /* Lock body scroll when mobile menu is open */
      body.menu-open {
        overflow: hidden;
      }
      /* Hide scrollbar for the mobile carousel */
      .hide-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
      }
      .hide-scrollbar::-webkit-scrollbar {
        display: none; /* Chrome, Safari and Opera */
      }
    </style>

    <script is:inline>
      // Form Submission Logic
      const form = document.getElementById('contact-form');
      const status = document.getElementById('contact-status');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        status.textContent = 'Sending...';
        status.classList.remove('hidden', 'text-red-700', 'text-green-700');

        try {
          const response = await fetch('/.netlify/functions/contact-submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!response.ok) throw new Error('Submission failed');

          form.reset();
          status.classList.add('text-green-700');
          status.textContent = 'Thanks, your enquiry has been sent.';
        } catch (err) {
          status.classList.add('text-red-700');
          status.textContent = 'Issue sending enquiry. Please email hamish@hmrsportsolutions.co directly.';
        }
      });

      // Mobile Menu Toggle Logic
      const mobileBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileLinks = document.querySelectorAll('.mobile-link');
      const menuIcon = mobileBtn?.querySelector('svg');

      const toggleMenu = () => {
        const isExpanded = mobileBtn.getAttribute('aria-expanded') === 'true';
        mobileBtn.setAttribute('aria-expanded', !isExpanded);
        
        if (!isExpanded) {
          mobileMenu.classList.remove('translate-x-full');
          document.body.classList.add('menu-open');
          // Switch to close (X) icon
          menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
        } else {
          mobileMenu.classList.add('translate-x-full');
          document.body.classList.remove('menu-open');
          // Switch to hamburger icon
          menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
        }
      };

      mobileBtn?.addEventListener('click', toggleMenu);
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          if (mobileBtn.getAttribute('aria-expanded') === 'true') toggleMenu();
        });
      });
    </script>
  </body>
</html>
