---
// Astro Component Script area - you can add imports here if needed
---

<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>HMR advisor | Independent advice for senior decision-makers</title>
    
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@900&family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface text-on-surface antialiased">
    <header class="fixed top-0 w-full z-50 bg-[#eefcfc]/80 dark:bg-[#032829]/80 backdrop-blur-md">
      <nav class="flex justify-between items-center w-full px-12 py-6 max-w-screen-2xl mx-auto">
        <div class="text-xl font-black uppercase tracking-tighter text-[#032829] dark:text-[#eefcfc]">
          <img alt="HMR Sport Solutions" class="h-12 w-auto object-contain" src="/assets/logo-horizontal-black.png" />
        </div>

        <div class="hidden md:flex items-center gap-8">
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#threshold">When to bring me in</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#advisory">How I help</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#evidence">Experience</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#principal">About</a>
          <a class="text-[#111e1e] dark:text-[#eefcfc] opacity-80 hover:opacity-100 hover:text-[#01696E] transition-all duration-300 body-sm font-normal tracking-wide" href="#dialogue">Contact</a>
        </div>

        <a class="bg-primary-container text-on-primary px-6 py-2.5 rounded-sm text-sm font-semibold tracking-tight hover:opacity-90 active:scale-[0.98] transition-all" href="#dialogue">
          Get in touch
        </a>
      </nav>
    </header>

    <main>
      <section class="relative min-h-screen flex items-center pt-24 px-12 overflow-hidden bg-surface-container-lowest">
        <div class="absolute inset-0 schematic-grid opacity-[0.03] pointer-events-none"></div>
        <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-[0.05] pointer-events-none">
          <svg fill="none" height="600" viewBox="0 0 600 600" width="600" xmlns="http://www.w3.org/2000/svg">
            <circle cx="200" cy="300" r="199.5" stroke="#01696E"></circle>
            <circle cx="400" cy="300" r="199.5" stroke="#01696E"></circle>
          </svg>
        </div>

        <div class="max-w-7xl mx-auto w-full relative z-10">
          <div class="max-w-5xl">
            <h1 class="font-archivo text-6xl md:text-8xl font-black tracking-tight leading-[0.95] text-primary mb-10">
              Independent advice when important decisions are still taking shape
            </h1>
            <p class="font-body text-xl md:text-2xl text-on-surface-variant max-w-2xl leading-relaxed mb-12">
              I work with organisations across sport, recreation, and public-sector settings on complex decisions involving facilities, investment, partnerships, and system response, before commitments are made and before weak assumptions turn into harder problems.
            </p>
            <div class="flex flex-wrap gap-6">
              <a class="bg-primary-container text-on-primary px-10 py-4 rounded-sm font-bold tracking-tight hover:opacity-90 transition-all" href="#dialogue">
                Get in touch
              </a>
              <a class="border border-outline-variant/30 text-on-surface px-10 py-4 rounded-sm font-bold tracking-tight hover:bg-surface-container transition-all" href="#evidence">
                View experience
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="py-32 px-12 bg-surface-container-low border-none" id="threshold">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12">
          <div class="md:col-span-4">
            <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4">01 / Timing</span>
            <h2 class="font-archivo text-4xl font-black text-on-surface mb-8">When to bring me in</h2>
          </div>
          <div class="md:col-span-8">
            <ul class="space-y-6 mb-16">
              <li class="flex items-start gap-6 group"><span class="material-symbols-outlined text-primary mt-1">arrow_right_alt</span><span class="text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">direction is not yet settled</span></li>
              <li class="flex items-start gap-6 group"><span class="material-symbols-outlined text-primary mt-1">arrow_right_alt</span><span class="text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">options are contested</span></li>
              <li class="flex items-start gap-6 group"><span class="material-symbols-outlined text-primary mt-1">arrow_right_alt</span><span class="text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">investment case is forming</span></li>
              <li class="flex items-start gap-6 group"><span class="material-symbols-outlined text-primary mt-1">arrow_right_alt</span><span class="text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">pressure to move, but readiness is unclear</span></li>
              <li class="flex items-start gap-6 group"><span class="material-symbols-outlined text-primary mt-1">arrow_right_alt</span><span class="text-2xl font-medium text-on-surface opacity-80 group-hover:opacity-100 transition-opacity">consequences of getting the next step wrong are material</span></li>
            </ul>
            <p class="font-body text-xl text-on-surface-variant max-w-2xl leading-relaxed">
              This is usually the point where independent advice adds most value, when the direction is still taking shape, the pressure to move is real, and the quality of the next step matters.
            </p>
          </div>
        </div>
      </section>

      <section class="py-32 px-12 bg-surface" id="advisory">
        <div class="max-w-7xl mx-auto">
          <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4">02 / Role</span>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
            <div>
              <h2 class="font-archivo text-4xl font-black text-on-surface mb-8">How I help</h2>
            </div>
            <div class="font-body text-xl text-on-surface space-y-8 leading-relaxed">
              <p>I provide independent advice when organisations need to decide what to do, why it stacks up, and whether the timing is right.</p>
              <p>The work usually involves clarifying the real decision, testing assumptions and investment logic, working through stakeholder complexity, and assessing sequencing, readiness, and risk.</p>
              <p>I am usually brought in early enough to question the brief, sharpen the case, and reduce the risk of premature lock-in.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-32 px-12 bg-surface-dim" id="evidence">
        <div class="max-w-7xl mx-auto">
          <div class="flex flex-col md:flex-row justify-between items-baseline mb-16 gap-8">
            <div>
              <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4">03 / Experience</span>
              <h2 class="font-archivo text-4xl font-black text-on-surface">Selected experience</h2>
            </div>
            <p class="text-on-surface-variant max-w-md">Experience across sport, recreation, local and central government, and decision-making around facilities, investment, access, and systems.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-px bg-outline-variant/10">
            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">PLANNING &amp; INVESTMENT</span>
                <h3 class="text-2xl font-bold mb-4">Local authority planning and investment</h3>
                <p class="text-on-surface-variant">Worked with Auckland local boards on sport and active recreation planning, access, and investment-related decisions.</p>
              </div>
            </div>

            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">LEASING</span>
                <h3 class="text-2xl font-bold mb-4">Public-sector systems and leasing</h3>
                <p class="text-on-surface-variant">Led cross-council work to improve how community leasing decisions support public and community benefit.</p>
              </div>
            </div>

            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">FACILITY DESIGN &amp; OPERATIONS</span>
                <h3 class="text-2xl font-bold mb-4">Hiwa – University of Auckland Recreation Centre</h3>
                <p class="text-on-surface-variant">Worked across design, facility transition, operational setup, and growth, with direct visibility into how early decisions carry through into operating reality.</p>
              </div>
            </div>

            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">SPORT SYSTEMS</span>
                <h3 class="text-2xl font-bold mb-4">National sport and system context</h3>
                <p class="text-on-surface-variant">Worked across Sport New Zealand in roles spanning sport development, system-level work, and management of the Balance is Better digital platform, with direct exposure to how strategy is translated into sector-facing tools and communication.</p>
              </div>
            </div>

            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">READINESS</span>
                <h3 class="text-2xl font-bold mb-4">Major-event readiness</h3>
                <p class="text-on-surface-variant">Worked within the FIFA Women’s World Cup host city programme across training venue settings.</p>
              </div>
            </div>

            <div class="bg-white py-12 px-8 min-h-[280px] flex flex-col">
              <div class="max-w-2xl">
                <span class="text-[11px] font-bold tracking-[0.18em] text-primary uppercase block mb-6">FUNDING</span>
                <h3 class="text-2xl font-bold mb-4">Funding and investment administration</h3>
                <p class="text-on-surface-variant">Managed a large regional KiwiSport funding portfolio, with direct responsibility for how investment decisions were administered.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-32 px-12 bg-surface" id="principal">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
          <div class="relative aspect-[4/5] bg-surface-dim overflow-hidden">
            <img alt="Portrait of Hamish Rogers" class="portrait-editorial object-cover w-full h-full transition-all duration-700" src="/assets/hamish-portrait.jpg" />
            <div class="absolute inset-0 border-[20px] border-surface"></div>
          </div>

          <div>
            <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4">04 / Principal</span>
            <h2 class="font-archivo text-4xl font-black text-on-surface mb-8">About Hamish Rogers</h2>
            <div class="font-body text-lg text-on-surface-variant space-y-6 leading-relaxed">
              <p>My experience has shown me that many important decisions are made before the real problem is fully clear and before the underlying logic has been properly tested.</p>
              <p>Having worked across sport, recreation, facilities, funding, and public-sector environments, I understand how ideas take shape inside organisations, how competing pressures influence direction, and where weak assumptions can harden into more difficult problems later.</p>
              <p>My role is to help bring more clarity to the decision in front of you, test the logic behind it, and improve the quality of the next step before commitments settle in the wrong place.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-32 px-12 bg-surface-container-low" id="dialogue">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
            <div class="md:col-span-5">
              <span class="font-label text-xs font-bold tracking-[0.2em] text-primary block mb-4">05 / Contact</span>
              <h2 class="font-archivo text-4xl font-black text-on-surface mb-8">Get in touch</h2>
              <p class="text-on-surface-variant text-lg mb-8 leading-relaxed">
                If you are working through a decision like this, get in touch.
              </p>
              <div class="p-6 bg-surface-container-lowest rounded-sm">
                <p class="text-sm font-bold uppercase tracking-widest text-primary mb-2">Direct contact</p>
                <a class="text-xl font-bold hover:text-primary transition-colors" href="mailto:hamish@hmrsportsolutions.co">hamish@hmrsportsolutions.co</a>
              </div>
            </div>

            <div class="md:col-span-7">
              <form class="space-y-8 bg-surface-container-lowest p-10 shadow-sm" id="contact-form">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                    <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-1 block" for="name">Name</label>
                    <input class="w-full bg-transparent border-none p-0 pb-2 focus:ring-0 text-on-surface" id="name" name="name" placeholder="John Doe" type="text" required />
                  </div>
                  <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                    <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-1 block" for="organisation">Organisation</label>
                    <input class="w-full bg-transparent border-none p-0 pb-2 focus:ring-0 text-on-surface" id="organisation" name="organisation" placeholder="Public Sector Org" type="text" />
                  </div>
                </div>

                <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-1 block" for="email">Email</label>
                  <input class="w-full bg-transparent border-none p-0 pb-2 focus:ring-0 text-on-surface" id="email" name="email" placeholder="email@organisation.gov.nz" type="email" required />
                </div>

                <div class="relative border-b border-outline-variant focus-within:border-primary transition-colors">
                  <label class="text-[10px] uppercase font-bold tracking-widest text-outline-variant mb-1 block" for="message">How can I help?</label>
                  <textarea class="w-full bg-transparent border-none p-0 pb-2 focus:ring-0 text-on-surface resize-none" id="message" name="message" placeholder="How can I help?" rows="3" required></textarea>
                </div>

                <button class="bg-primary-container text-on-primary w-full md:w-auto px-12 py-4 font-bold tracking-tight hover:opacity-90 transition-all" type="submit">
                  Send enquiry
                </button>
                <p class="text-sm hidden" id="contact-status"></p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-[#e8f6f6] dark:bg-[#021d1e] w-full py-20 px-12">
      <div class="flex flex-col md:flex-row justify-between items-end w-full max-w-screen-2xl mx-auto gap-8">
        <div class="space-y-4">
          <div class="text-lg font-black text-[#032829] dark:text-[#eefcfc] uppercase tracking-tighter">
            HMR Sport Solutions
          </div>
          <p class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60">
            HMR Sport Solutions © 2026
          </p>
        </div>
        <div class="flex gap-8">
          <a class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60 hover:opacity-100 hover:text-[#01696E] underline decoration-px underline-offset-4 transition-all" href="#">LinkedIn</a>
          <a class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60 hover:opacity-100 hover:text-[#01696E] underline decoration-px underline-offset-4 transition-all" href="#">Privacy Policy</a>
          <a class="body-sm font-normal text-[#111e1e] dark:text-[#eefcfc] tracking-wide opacity-60 hover:opacity-100 hover:text-[#01696E] underline decoration-px underline-offset-4 transition-all" href="#">Terms</a>
        </div>
      </div>
    </footer>

    <style is:global>
      /* Restore original CSS styles via Astro's global style tag */
      body { font-family: 'Inter', sans-serif; background-color: #eefcfc; color: #111e1e; }
      .font-archivo { font-family: 'Archivo', sans-serif; }
      .schematic-grid {
        background-image: linear-gradient(#bec9c9 0.5px, transparent 0.5px), linear-gradient(90deg, #bec9c9 0.5px, transparent 0.5px);
        background-size: 40px 40px;
      }
      .portrait-editorial {
        filter: grayscale(100%) contrast(1.03) brightness(1.01);
        transform: scale(1.015);
      }
      .portrait-editorial:hover {
        filter: grayscale(55%) contrast(1.03) brightness(1.01);
      }
    </style>

    <script is:inline>
      // Form handling script
      const form = document.getElementById('contact-form');
      const status = document.getElementById('contact-status');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        try {
          const response = await fetch('/.netlify/functions/contact-submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (!response.ok) throw new Error('Failed to submit enquiry');

          form.reset();
          status?.classList.remove('hidden', 'text-red-700');
          status?.classList.add('text-green-700');
          if (status) status.textContent = 'Thanks, your enquiry has been sent.';
        } catch {
          status?.classList.remove('hidden', 'text-green-700');
          status?.classList.add('text-red-700');
          if (status) status.textContent = 'Sorry, there was an issue sending your enquiry. Please email directly.';
        }
      });
    </script>
  </body>
</html>
