---
import lineArtOne from '../assets/img/line-art-1.svg';
---

<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div>
      <p class="kicker">HMR Sport Solutions</p>
      <h1 id="hero-title">Independent advice when important decisions are still taking shape</h1>
      <p>
        I work with organisations facing complex decisions around facilities, investment and partnerships, before
        commitments are made and before weak assumptions turn into harder problems.
      </p>
      <div class="hero-actions">
        <a class="btn" href="#contact">Get in touch</a>
        <a class="btn-secondary" href="#experience">View experience</a>
      </div>
    </div>
    <div class="hero-art" aria-hidden="true">
      <img src={lineArtOne.src} alt="" loading="lazy" decoding="async" />
    </div>
  </div>
</section>
